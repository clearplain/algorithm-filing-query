{
  "name": "algorithm-filing-query",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build --base=./",
    "preview": "vite preview --host 127.0.0.1",
    "data:build": "python scripts/build_data.py",
    "data:refresh": "python scripts/build_data.py --fetch-remote",
    "verify": "npm run data:build && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
